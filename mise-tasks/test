#!/usr/bin/env bash
#MISE description="Run plugin tests - install and execute tool"
set -euo pipefail

mise plugin link --force seaweedfs .
mise cache clear
mise install seaweedfs@4.30

# Capture and display the output while also verifying it
output=$(mise exec "seaweedfs@4.30" -- "weed" version)
echo "weed output: ${output}"

if echo "${output}" | grep -q '4.30'; then
  echo "✓ Tests passed"
else
  echo "✗ Test failed: expected version seaweedfs@4.30"
  exit 1
fi
